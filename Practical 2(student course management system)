SELECT * FROM Students WHERE age > 21;
SELECT * FROM Students WHERE department = 'CS';
SELECT * FROM Students ORDER BY name ASC;
SELECT * FROM Courses ORDER BY credits DESC;
SELECT c.course_name, COUNT(e.student_id) AS student_count
FROM Courses c
JOIN Enrollment e ON c.course_id = e.course_id
GROUP BY c.course_name;
SELECT department, AVG(age) AS avg_age
FROM Students
GROUP BY department;
SELECT name
FROM Students
WHERE student_id IN (
 SELECT student_id
 FROM Enrollment
 WHERE course_id IN (
 SELECT course_id
 FROM Courses
 WHERE credits > 3
 )
);
SELECT course_name
FROM Courses
WHERE course_id IN (
 SELECT course_id
 FROM Enrollment
 GROUP BY course_id
 HAVING COUNT(student_id) > 1
);
CREATE INDEX idx_student_age ON Students(age);
CREATE INDEX idx_course_credits ON Courses(credits);
CREATE INDEX idx_enrollment ON Enrollment(student_id, course_id);
