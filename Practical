CREATE TABLE SALES (
SALE_ID NUMBER PRIMARY KEY,
PRODUCT_NAME VARCHAR2(50),
QUANTITY NUMBER,
PRICE NUMBER(10,2),
SALE_DATE DATE
);
CREATE OR REPLACE PROCEDURE ADD_SALE(
P_ID NUMBER,
P_NAME VARCHAR2,
P_QTY NUMBER,
P_PRICE NUMBER,
P_DATE DATE
)
IS
BEGIN
INSERT INTO SALES
VALUES (P_ID, P_NAME, P_QTY, P_PRICE, P_DATE);
COMMIT;
END;
/
CREATE OR REPLACE FUNCTION GET_TOTAL_SALES
RETURN NUMBER
IS
TOTAL_SALES NUMBER;
BEGIN
SELECT SUM(QUANTITY * PRICE)
INTO TOTAL_SALES
FROM SALES;
RETURN TOTAL_SALES;
END;
/
BEGIN
