CREATE DATABASE employee_db;
USE employee_db;
CREATE TABLE EMPLOYEE (
 EMP_ID INT PRIMARY KEY,
 EMP_NAME VARCHAR(50),
 DEPARTMENT VARCHAR(30),
 SALARY DECIMAL(10,2)
);
CREATE TABLE EMPLOYEE_AUDIT (
 AUDIT_ID INT AUTO_INCREMENT PRIMARY KEY,
 EMP_ID INT,
 ACTION_TYPE VARCHAR(10),
 ACTION_DATE DATE
);
DELIMITER //
CREATE TRIGGER emp_insert
AFTER INSERT ON EMPLOYEE
FOR EACH ROW
BEGIN
INSERT INTO EMPLOYEE_AUDIT VALUES (NULL, NEW.EMP_ID, 'INSERT', CURDATE());
END //
DELIMITER ;
DELIMITER //
CREATE TRIGGER emp_update
AFTER UPDATE ON EMPLOYEE
FOR EACH ROW
BEGIN
INSERT INTO EMPLOYEE_AUDIT VALUES (NULL, NEW.EMP_ID, 'UPDATE', CURDATE());
END //
DELIMITER ;
DELIMITER //
CREATE TRIGGER emp_delete
AFTER DELETE ON EMPLOYEE
FOR EACH ROW
BEGIN
INSERT INTO EMPLOYEE_AUDIT VALUES (NULL, OLD.EMP_ID, 'DELETE', CURDATE());
END //
DELIMITER ;
INSERT INTO EMPLOYEE VALUES (1, 'Rahul', 'IT', 50000);
INSERT INTO EMPLOYEE VALUES (2, 'Sneha', 'HR', 40000);
INSERT INTO EMPLOYEE VALUES (3, 'Amit', 'IT', 60000);
SELECT * FROM EMPLOYEE_AUDIT;
DELIMITER //
CREATE PROCEDURE update_salary()
BEGIN
DECLARE done INT DEFAULT 0;
DECLARE id INT;
DECLARE sal DECIMAL(10,2);
DECLARE cur CURSOR FOR
SELECT EMP_ID, SALARY FROM EMPLOYEE WHERE DEPARTMENT='IT';
DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;
OPEN cur;
read_loop: LOOP
FETCH cur INTO id, sal;
IF done THEN
LEAVE read_loop;
END IF;
UPDATE EMPLOYEE SET SALARY = sal * 1.10 WHERE EMP_ID = id;
END LOOP;
CLOSE cur;
END //
DELIMITER ;
CALL update_salary();
SELECT * FROM EMPLOYEE;
SELECT * FROM EMPLOYEE_AUDIT;
